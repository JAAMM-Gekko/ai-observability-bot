# Copy this file to .env and fill in your values
# Never commit .env to git

OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=openai:gpt-4o

# RAG: PostgreSQL + pgvector (must match embedding column dimension, default 1536 for text-embedding-3-small)
DATABASE_URL=postgresql://chatbot:chatbot_password@postgres:5432/chatbot_db
RAG_TENANT_ID=704bd8d9-2791-4f6b-ba69-7f7cf065ba88
FAQ_EXCEL_PATH=/app/Cannabis FAQ_expanded_claude_rewritten.xlsx

# OpenTelemetry
OTEL_ENDPOINT=http://otel-collector:4318
OTEL_SKIP_SPAN_TEST=0

# Splunk HEC
SPLUNK_HEC_TOKEN=your-hec-token
SPLUNK_HEC_URL=https://<splunk-ip>:8088

# Email notifications
SENDER_EMAIL=your@gmail.com
SENDER_PASSWORD=your-app-password
RECIPIENT_EMAIL=your@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Sentiment escalation
FRUSTRATION_THRESHOLD=0.6
ESCALATION_TRIGGER_COUNT=3
